# Gitleaks configuration for {{project_name}}
# Generated by iw-oss-publish. Customize per-project rules below.
# Docs: https://github.com/gitleaks/gitleaks#configuration

title = "{{project_name}} gitleaks config"

# Extend the default gitleaks ruleset (recommended — inherits ~150 built-in detectors)
[extend]
useDefault = true

# ---------------------------------------------------------------
# IW-specific custom rules
# ---------------------------------------------------------------

[[rules]]
id = "iw-internal-email"
description = "Internal {{company_brand}} employee email address"
regex = '''[a-zA-Z0-9._%+-]+@(?:{{internal_email_domains_regex}})'''
tags = ["internal", "pii"]

[[rules]]
id = "iw-internal-fqdn"
description = "Internal {{company_brand}} hostname (.internal, .corp, .local, .lan, .intranet)"
regex = '''[a-zA-Z0-9][a-zA-Z0-9-]{0,62}\.(?:internal|corp|local|lan|intranet)\b'''
tags = ["internal", "infra"]

[[rules]]
id = "iw-rfc1918-ip"
description = "RFC 1918 private IP address (likely internal infrastructure reference)"
regex = '''\b(?:10(?:\.[0-9]{1,3}){3}|172\.(?:1[6-9]|2[0-9]|3[01])(?:\.[0-9]{1,3}){2}|192\.168(?:\.[0-9]{1,3}){2})\b'''
tags = ["internal", "infra"]

# ---------------------------------------------------------------
# Per-rule allowlists — targeted suppression for common false positives
# ---------------------------------------------------------------

# Stripe test-mode keys are clearly non-production; suppress at the rule level
# rather than globally so real sk_live_ / pk_live_ keys still fire.
[[rules]]
id = "stripe-access-token"
[rules.allowlist]
regexes = ['''(?i)(?:sk|pk|rk)_test_''']

# ---------------------------------------------------------------
# Allowlists — paths and values that should NOT trigger findings
# ---------------------------------------------------------------

[allowlist]
description = "Global allowlists for {{project_name}}"

# Skip documentation, test fixtures, API contract specs, generated artefacts,
# vendored dependencies, build output, lockfiles, and the skill's own output.
#
# IMPORTANT: gitleaks emits absolute paths when invoked with --source <abs>,
# so each regex must match anywhere in the path (anchor `(?:^|/)`), not just
# at the start of a relative path.
paths = [
  '''(?i)(?:^|/)docs/''',
  '''(?i)(?:^|/)tests?/fixtures?/''',
  '''(?i)(?:^|/)examples?/''',
  '''(?i)(?:^|/)api[-_]?contracts?/''',  # OpenAPI / contract specs: example values are not secrets
  '''(?i)(?:^|/)seeds?/''',              # database seed files with dev-only placeholder data
  '''(?i)(?:^|/)test[-_]?data/''',       # static test data directories
  '''(?i)(?:^|/)mock[-_]?data/''',       # mock/stub data directories
  '''(?i)(?:^|/)\.iw/''',
  '''(?i)(?:^|/)\.git/''',
  '''(?i)(?:^|/)\.venv/''',
  '''(?i)(?:^|/)venv/''',
  '''(?i)(?:^|/)node_modules/''',
  '''(?i)(?:^|/)dist/''',
  '''(?i)(?:^|/)build/''',
  '''(?i)(?:^|/)__pycache__/''',
  '''(?i)(?:^|/)logs?/''',
  '''(?i)(?:^|/)allure-report/''',
  '''(?i)(?:^|/)allure-results/''',
  '''(?i)(?:^|/)coverage/''',
  '''(?i)(?:^|/)htmlcov/''',
  '''(?i)\.pyc$''',
  '''(?i)\.lock$''',
  '''(?i)(?:^|/)package-lock\.json$''',
  '''(?i)(?:^|/)yarn\.lock$''',
  '''(?i)(?:^|/)pnpm-lock\.yaml$''',
  '''(?i)(?:^|/)uv\.lock$''',
  '''(?i)(?:^|/)poetry\.lock$''',
  '''(?i)(?:^|/)Pipfile\.lock$''',
  '''(?i)\.min\.(?:js|css)$''',
]

# Common example-value patterns that are not real secrets.
regexes = [
  '''AKIAIOSFODNN7EXAMPLE''',            # AWS docs example key
  '''wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY''',  # AWS docs example secret
  '''(?i)example\.(com|org|net|invalid)''',
  '''(?i)localhost''',
  '''(?i)127\.0\.0\.1''',
  '''(?i)0\.0\.0\.0''',
  '''(?i)\btest\b.*\btoken\b''',         # "test token" in prose
  '''(?i)\bchangeme\b''',               # placeholder value
  '''(?i)replace[-_]with[-_]''',        # placeholder instruction prefix
  '''(?i)insert[-_]your[-_]''',         # placeholder instruction prefix
  '''(?i)\bpassword[0-9]{2,4}[!@#]?\b''', # password123, password456! — obvious dev seed values
]

# ---------------------------------------------------------------
# Project-specific tuning (add entries below as false positives surface)
# ---------------------------------------------------------------
#
# Add extra paths:
#   paths = [ '''(?i)(?:^|/)my-special-dir/''' ]
#
# Add extra value patterns:
#   regexes = [ '''(?i)my-placeholder-pattern''' ]
#
# Add per-rule allowlists (preferred over global regexes — more targeted):
#   [[rules]]
#   id = "aws-access-token"
#   [rules.allowlist]
#   regexes = ['''AKIA[0-9A-Z]{16}_SANDBOX''']
#
# ---------------------------------------------------------------
# Tips for tuning
# ---------------------------------------------------------------
#
# - Run locally: gitleaks detect --source . --log-opts="-1 HEAD" --verbose
# - Scan history: gitleaks detect --source . --log-opts="--all"
# - Add real false-positive patterns to `allowlist.regexes` as they surface.
# - Prefer per-rule allowlists over global regexes to avoid blanket suppression.
