# Exclude large / irrelevant directories from the E2E Docker build context.
# Without this, docker builds upload the entire .worktrees tree (~1GB+)
# on every rebuild, which slows the daemon down.

.git/
.worktrees/
.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
allure-results/
allure-report/
dist/
build/
*.egg-info/

# Local dev artefacts
ai-dev/active/
ai-dev/completed/

# BUT: include e2e_fixtures/ subtrees — these declare the DB rows a work
# item's browser verification needs (see scripts/e2e_seed.py fixture
# discovery). Without this line, fixtures never reach the E2E container
# and verifications that depend on seed data silently fail.
!ai-dev/active/*/e2e_fixtures/
!ai-dev/active/*/e2e_fixtures/**
!ai-dev/archive/*/e2e_fixtures/
!ai-dev/archive/*/e2e_fixtures/**

.tmp/
.env
.env.local
.dashboard.pid
.daemon.pid
*.log

# Vendor binaries / caches
.playwright/
