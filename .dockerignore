# Exclude large / irrelevant directories from the E2E Docker build context.
# Without this, docker builds upload the entire .worktrees tree (~1GB+)
# on every rebuild, which slows the daemon down.

.git/
.worktrees/
.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
allure-results/
allure-report/
dist/
build/
*.egg-info/

# Local dev artefacts
ai-dev/active/
ai-dev/completed/
.tmp/
.env
.env.local
.dashboard.pid
.daemon.pid
*.log

# Vendor binaries / caches
.playwright/
