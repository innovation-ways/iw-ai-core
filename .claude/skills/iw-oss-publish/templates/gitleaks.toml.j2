# Gitleaks configuration for {{project_name}}
# Generated by iw-oss-publish. Customize per-project rules below.
# Docs: https://github.com/gitleaks/gitleaks#configuration

title = "{{project_name}} gitleaks config"

# Extend the default gitleaks ruleset (recommended — inherits ~150 built-in detectors)
[extend]
useDefault = true

# ---------------------------------------------------------------
# IW-specific custom rules
# ---------------------------------------------------------------

[[rules]]
id = "iw-internal-email"
description = "Internal {{company_brand}} employee email address"
regex = '''[a-zA-Z0-9._%+-]+@(?:{{internal_email_domains_regex}})'''
tags = ["internal", "pii"]

[[rules]]
id = "iw-internal-fqdn"
description = "Internal {{company_brand}} hostname (.internal, .corp, .local, .lan, .intranet)"
regex = '''[a-zA-Z0-9][a-zA-Z0-9-]{0,62}\.(?:internal|corp|local|lan|intranet)\b'''
tags = ["internal", "infra"]

[[rules]]
id = "iw-rfc1918-ip"
description = "RFC 1918 private IP address (likely internal infrastructure reference)"
regex = '''\b(?:10(?:\.[0-9]{1,3}){3}|172\.(?:1[6-9]|2[0-9]|3[01])(?:\.[0-9]{1,3}){2}|192\.168(?:\.[0-9]{1,3}){2})\b'''
tags = ["internal", "infra"]

# ---------------------------------------------------------------
# Allowlists — paths and values that should NOT trigger findings
# ---------------------------------------------------------------

[allowlist]
description = "Global allowlists for {{project_name}}"

# Skip documentation, test fixtures, and the skill's own output.
paths = [
  '''(?i)^docs/''',
  '''(?i)^tests/fixtures/''',
  '''(?i)^examples/''',
  '''(?i)^\.iw/''',
]

# Common example-value patterns that are not real secrets.
regexes = [
  '''AKIAIOSFODNN7EXAMPLE''',            # AWS docs example key
  '''wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY''',  # AWS docs example secret
  '''(?i)example\.(com|org|net|invalid)''',
  '''(?i)localhost''',
  '''(?i)127\.0\.0\.1''',
  '''(?i)0\.0\.0\.0''',
  '''(?i)\btest\b.*\btoken\b''',         # "test token" in prose
]

# Per-rule allowlists — finer control when the rule catches false positives.
# [[rules]]
# id = "aws-access-token"
# [rules.allowlist]
# regexes = ['''AKIA[0-9A-Z]{16}_SANDBOX''']

# ---------------------------------------------------------------
# Tips for tuning
# ---------------------------------------------------------------
#
# - Add real false-positive patterns to `allowlist.regexes` as they surface.
# - Add per-rule allowlists (by rule id) to avoid blanket allowlists.
# - Run locally: gitleaks detect --source . --no-git --verbose
# - Scan history: gitleaks detect --source . --log-opts="--all"
