    },
    {
      "step": "S04",
      "agent": "code-review-final-impl",
      "description": "Final cross-agent review",
      "prompt": "prompts/CR001_S04_CodeReview_Final_prompt.md"
    },
    {
      "step": "S05",
      "agent": "quality-validation-impl",
      "description": "Run lint, type check, and test quality gates",
