  "steps": [
    {
      "step": "S01",
      "agent": "backend-impl",
      "description": "Add `# nosemgrep: <rule>` annotations to the 15 Python lines flagged by Semgrep (Classes A=12, D=1, E=2). Preserve every existing `# nosec` / `# noqa` marker (Invariant I1). Add four `--exclude-rule` flags to the `Makefile` `security-sast` target (Classes C=unquoted-attribute-var, F=var-in-href, G=var-in-script-tag, H=plaintext-http-link) with an inline rationale comment block above the target. Append the Semgrep triage section to docs/IW_AI_Core_Testing_Strategy.md. No behavioural code change.",
      "prompt": "prompts/CR-00051_S01_Backend_prompt.md",
      "timeout": 1800
    },
    {
      "step": "S02",
      "agent": "code-review-impl",
      "description": "Review S01: every per-line suppression has a same-line rationale; no `# nosec` / `# noqa` was removed (Invariant I1); only the listed Python lines and the Makefile `security-sast` target (plus the triage doc) were touched; no behaviour changed; the four Makefile `--exclude-rule` flags are rule-id-specific (Invariant I4) and carry rationale comments; the triage doc section is accurate and self-contained.",
      "prompt": "prompts/CR-00051_S02_CodeReview_prompt.md"
    },
    {
      "step": "S03",
      "agent": "frontend-impl",
      "description": "Add `{# nosemgrep: <rule> — <rationale> #}` to the 16 Class B template lines (template-unescaped-with-safe `| safe` filter sites). No edits to `db_guard.html` or to any of the 12 macro-caller files — Class C is handled by S01's Makefile `--exclude-rule` flag.",
      "prompt": "prompts/CR-00051_S03_Frontend_prompt.md",
