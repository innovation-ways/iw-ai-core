  "id": "F-00069",
  "type": "Feature",
  "title": "Test Execution, Coverage Gate, Reports, and Coverage Dashboard View",
  "browser_verification": true,
  "steps": [
    {
      "step": "S01",
      "agent": "backend-impl",
      "description": "Backend: pyproject (xdist, pytest-cov, coverage config + threshold), Makefile (test-parallel, allure-report, e2e-{health,logs,stats}), .gitignore, coverage_service.py, /system/coverage router, baseline measurement",
      "prompt": "prompts/F-00069_S01_Backend_prompt.md"
    },
    {
      "step": "S02",
      "agent": "frontend-impl",
      "description": "Frontend: /system/coverage Jinja templates, drill-down fragment, base.html nav entry",
      "prompt": "prompts/F-00069_S02_Frontend_prompt.md"
    },
    {
      "step": "S03",
      "agent": "code-review-impl",
      "description": "Code review of S01 (backend, pyproject, Makefile, coverage service, router)",
      "prompt": "prompts/F-00069_S03_CodeReview_Backend_prompt.md"
    },
    {
      "step": "S04",
      "agent": "code-review-impl",
      "description": "Code review of S02 (templates, nav, htmx)",
      "prompt": "prompts/F-00069_S04_CodeReview_Frontend_prompt.md"
    },
    {
      "step": "S05",
      "agent": "tests-impl",
      "description": "Tests: coverage_service unit tests, /system/coverage page + fragment dashboard tests, Makefile surface smoke test",
      "prompt": "prompts/F-00069_S05_Tests_prompt.md"
    },
    {
      "step": "S06",
      "agent": "code-review-impl",
      "description": "Code review of S05 (tests)",
      "prompt": "prompts/F-00069_S06_CodeReview_Tests_prompt.md"
    },
    {
      "step": "S07",
      "agent": "code-review-final-impl",
      "description": "Cross-layer global review of all S01-S05 work",
      "prompt": "prompts/F-00069_S07_CodeReview_Final_prompt.md"
    },
    {
      "step": "S08",
      "agent": "qv-gate",
      "gate": "lint",
      "command": "make lint",
      "description": "QV: Linting"
    },
    {
      "step": "S09",
      "agent": "qv-gate",
      "gate": "format",
      "command": "make format",
      "description": "QV: Formatting"
    },
    {
      "step": "S10",
      "agent": "qv-gate",
      "gate": "typecheck",
      "command": "make typecheck",
      "description": "QV: Type checking"
    },
    {
      "step": "S11",
      "agent": "qv-gate",
      "gate": "unit-tests",
      "command": "make test-unit",
      "description": "QV: Unit tests (coverage threshold enforced)"
    },
    {
      "step": "S12",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": "make allure-integration",
      "description": "QV: Integration tests",
      "timeout": 900
    },
    {
      "step": "S13",
      "agent": "qv-browser",
      "description": "QV: Browser verification — /system/coverage page renders with data, drill-down works, empty state, nav entry, no regressions",
      "prompt": "prompts/F-00069_S13_BrowserVerification_prompt.md"
    }
  ]
}
