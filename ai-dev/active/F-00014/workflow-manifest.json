{
  "id": "F-00014",
  "type": "Feature",
  "title": "Project-Level Documentation System — Polish (Phase 4)",
  "browser_verification": false,
  "steps": [
    {
      "step": "S01",
      "agent": "backend-impl",
      "description": "diff_versions, validate_links, export_bundle, search_docs_global, broken_links column, iw docs-export CLI",
      "prompt": "prompts/F-00014_S01_Backend_prompt.md"
    },
    {
      "step": "S02",
      "agent": "api-impl",
      "description": "Diff route, export route, link validation route, global /docs search page and API",
      "prompt": "prompts/F-00014_S02_API_prompt.md",
      "parallel_with": "S03"
    },
    {
      "step": "S03",
      "agent": "frontend-impl",
      "description": "Version diff viewer, global search page, multi-select export, broken links callout, top-level nav Docs entry",
      "prompt": "prompts/F-00014_S03_Frontend_prompt.md",
      "parallel_with": "S02"
    },
    {
      "step": "S04",
      "agent": "tests-impl",
      "description": "Diff, export ZIP, link validation, global search integration tests, all boundary cases",
      "prompt": "prompts/F-00014_S04_Tests_prompt.md"
    },
    {
      "step": "S05",
      "agent": "code-review-final-impl",
      "description": "Final cross-agent review: all 7 AC, security (ZIP traversal, SSRF, XSS in diff), all 5 invariants",
      "prompt": "prompts/F-00014_S05_CodeReview_Final_prompt.md"
    },
    {
      "step": "S06",
      "agent": "qv-gate",
      "gate": "lint",
      "command": "make lint",
      "description": "QV: Linting"
    },
    {
      "step": "S07",
      "agent": "qv-gate",
      "gate": "format",
      "command": "make format-check",
      "description": "QV: Formatting"
    },
    {
      "step": "S08",
      "agent": "qv-gate",
      "gate": "typecheck",
      "command": "make type-check",
      "description": "QV: Type checking"
    },
    {
      "step": "S09",
      "agent": "qv-gate",
      "gate": "arch-check",
      "command": "make arch-check",
      "description": "QV: Architecture"
    },
    {
      "step": "S10",
      "agent": "qv-gate",
      "gate": "security-sast",
      "command": "make security-sast",
      "description": "QV: Security SAST"
    },
    {
      "step": "S11",
      "agent": "qv-gate",
      "gate": "unit-tests",
      "command": "make test-unit",
      "description": "QV: Unit tests"
    },
    {
      "step": "S12",
      "agent": "qv-gate",
      "gate": "frontend-tests",
      "command": "make test-frontend",
      "description": "QV: Frontend tests"
    },
    {
      "step": "S13",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": "make allure-integration",
      "description": "QV: Integration tests",
      "timeout": 900
    }
  ]
}
