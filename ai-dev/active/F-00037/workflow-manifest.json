{
  "id": "F-00037",
  "type": "Feature",
  "title": "Doc-Type Guides — Editable Editorial Guidelines",
  "browser_verification": false,
  "steps": [
    {
      "step": "S01",
      "agent": "database-impl",
      "description": "Migration: create doc_type_guides table with seed data; add guide_snapshot to doc_generation_jobs",
      "prompt": "prompts/F-00037_S01_Database_prompt.md"
    },
    {
      "step": "S02",
      "agent": "backend-impl",
      "description": "DocTypeGuide model; DocService.get_type_guide / save_type_guide; update create_doc_job to snapshot guide",
      "prompt": "prompts/F-00037_S02_Backend_prompt.md"
    },
    {
      "step": "S03",
      "agent": "code-review-impl",
      "description": "Code review of S02 Backend implementation",
      "prompt": "prompts/F-00037_S03_CodeReview_Backend_prompt.md"
    },
    {
      "step": "S04",
      "agent": "tests-impl",
      "description": "Integration tests: seed data present, get/save round-trip, snapshot captured in job",
      "prompt": "prompts/F-00037_S04_Tests_prompt.md"
    },
    {
      "step": "S05",
      "agent": "code-review-final-impl",
      "description": "Global review: completeness, consistency, full test suite",
      "prompt": "prompts/F-00037_S05_CodeReview_Final_prompt.md"
    },
    {
      "step": "S06",
      "agent": "qv-gate",
      "gate": "lint",
      "command": ".venv/bin/python -m ruff check orch/ tests/",
      "description": "QV: Linting"
    },
    {
      "step": "S07",
      "agent": "qv-gate",
      "gate": "format",
      "command": ".venv/bin/python -m ruff format --check orch/ tests/",
      "description": "QV: Formatting"
    },
    {
      "step": "S08",
      "agent": "qv-gate",
      "gate": "typecheck",
      "command": ".venv/bin/python -m mypy orch/db/models.py orch/doc_service.py",
      "description": "QV: Type checking"
    },
    {
      "step": "S09",
      "agent": "qv-gate",
      "gate": "unit-tests",
      "command": ".venv/bin/pytest tests/unit/ -x --timeout=60 -q 2>/dev/null || echo 'No unit tests — OK'",
      "description": "QV: Unit tests"
    },
    {
      "step": "S10",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": ".venv/bin/pytest tests/integration/ -x --timeout=300 -q",
      "description": "QV: Integration tests",
      "timeout": 600
    }
  ]
}
