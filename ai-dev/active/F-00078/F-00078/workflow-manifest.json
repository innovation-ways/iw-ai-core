{
  "_note": "This file is a design-time snapshot and may be out of date. For current step state, run: iw item-status <ID> --json. The DB is the authoritative source of truth (CR-00023).",
  "id": "F-00078",
  "type": "Feature",
  "title": "Per-project self-assessment step with copy-paste fix prompts",
  "browser_verification": false,
  "scope": {
    "allowed_paths": [
      "orch/db/models.py",
      "orch/db/migrations/versions/**",
      "orch/daemon/project_registry.py",
      "orch/daemon/execution_report.py",
      "orch/daemon/batch_manager.py",
      "orch/daemon/state_machine.py",
      "orch/cli/step_commands.py",
      "orch/self_assess.py",
      "dashboard/templates/fragments/item_execution_report.html",
      "dashboard/static/styles.css",
      "executor/step_executor_lib.sh",
      "executor/step_executor.sh",
      "skills/iw-item-analyze/**",
      "skills/iw-new-feature/**",
      "skills/iw-new-cr/**",
      "skills/iw-new-incident/**",
      "skills/iw-workflow/**",
      "templates/design/SelfAssess_Prompt_Template.md",
      ".claude/skills/iw-item-analyze/**",
      ".claude/skills/iw-new-feature/**",
      ".claude/skills/iw-new-cr/**",
      ".claude/skills/iw-new-incident/**",
      ".claude/skills/iw-workflow/**",
      "ai-dev/templates/SelfAssess_Prompt_Template.md",
      "tests/**"
    ]
  },
  "steps": [
    {
      "step": "S01",
      "agent": "database-impl",
      "description": "Add self_assess to StepType enum + Alembic migration",
      "prompt": "prompts/F-00078_S01_Database_prompt.md"
    },
    {
      "step": "S02",
      "agent": "code-review-impl",
      "description": "Review S01 (database)",
      "prompt": "prompts/F-00078_S02_CodeReview_Database_prompt.md"
    },
    {
      "step": "S03",
      "agent": "backend-impl",
      "description": "ProjectConfig.self_assess_enabled + orch/self_assess.py + soft-step semantics + step-done --analysis-json",
      "prompt": "prompts/F-00078_S03_Backend_prompt.md"
    },
    {
      "step": "S04",
      "agent": "code-review-impl",
      "description": "Review S03 (backend)",
      "prompt": "prompts/F-00078_S04_CodeReview_Backend_prompt.md"
    },
    {
      "step": "S05",
      "agent": "frontend-impl",
      "description": "Execution Report extension: load findings + render Self-Assessment section + clipboard buttons",
      "prompt": "prompts/F-00078_S05_Frontend_prompt.md"
    },
    {
      "step": "S06",
      "agent": "code-review-impl",
      "description": "Review S05 (frontend)",
      "prompt": "prompts/F-00078_S06_CodeReview_Frontend_prompt.md"
    },
    {
      "step": "S07",
      "agent": "template-impl",
      "description": "Migrate iw-item-analyze skill to OpenCode + update design skills + new prompt template + sync",
      "prompt": "prompts/F-00078_S07_Template_prompt.md"
    },
    {
      "step": "S08",
      "agent": "code-review-impl",
      "description": "Review S07 (skills + templates)",
      "prompt": "prompts/F-00078_S08_CodeReview_Template_prompt.md"
    },
    {
      "step": "S09",
      "agent": "tests-impl",
      "description": "Unit + integration tests for parser, soft-step, registry round-trip, dashboard render, skill injection",
      "prompt": "prompts/F-00078_S09_Tests_prompt.md"
    },
    {
      "step": "S10",
      "agent": "code-review-impl",
      "description": "Review S09 (tests)",
      "prompt": "prompts/F-00078_S10_CodeReview_Tests_prompt.md"
    },
    {
      "step": "S11",
      "agent": "code-review-final-impl",
      "description": "Global cross-agent review",
      "prompt": "prompts/F-00078_S11_CodeReview_Final_prompt.md"
    },
    {
      "step": "S12",
      "agent": "qv-gate",
      "gate": "lint",
      "command": "make lint",
      "description": "QV: Linting"
    },
    {
      "step": "S13",
      "agent": "qv-gate",
      "gate": "format",
      "command": "make format-check",
      "description": "QV: Formatting"
    },
    {
      "step": "S14",
      "agent": "qv-gate",
      "gate": "typecheck",
      "command": "make type-check",
      "description": "QV: Type checking"
    },
    {
      "step": "S15",
      "agent": "qv-gate",
      "gate": "unit-tests",
      "command": "make test-unit",
      "description": "QV: Unit tests"
    },
    {
      "step": "S16",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": "make test-integration",
      "description": "QV: Integration tests",
      "timeout": 900
    }
  ]
