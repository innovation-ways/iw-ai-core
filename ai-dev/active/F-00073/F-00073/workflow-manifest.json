  "id": "F-00073",
  "type": "Feature",
  "title": "Smoke Gate + Active Test CI + Logging Tests",
  "browser_verification": false,
  "depends_on": ["F-00069"],
  "steps": [
    {
      "step": "S01",
      "agent": "backend-impl",
      "description": "Backend: pyproject smoke marker, ~10 smoke-marked tests, make smoke target, tests/unit/test_logging.py, .github/workflows/test-quality.yml",
      "prompt": "prompts/F-00073_S01_Backend_prompt.md"
    },
    {
      "step": "S02",
      "agent": "code-review-impl",
      "description": "Code review of S01 (markers + smoke set + workflow + logging tests)",
      "prompt": "prompts/F-00073_S02_CodeReview_prompt.md"
    },
    {
      "step": "S03",
      "agent": "tests-impl",
      "description": "Tests: smoke regression guard appended to tests/unit/test_make_targets.py",
      "prompt": "prompts/F-00073_S03_Tests_prompt.md"
    },
    {
      "step": "S04",
      "agent": "code-review-impl",
      "description": "Code review of S03 (regression guard)",
      "prompt": "prompts/F-00073_S04_CodeReview_Tests_prompt.md"
    },
    {
      "step": "S05",
      "agent": "code-review-final-impl",
      "description": "Cross-layer global review",
      "prompt": "prompts/F-00073_S05_CodeReview_Final_prompt.md"
    },
    {
      "step": "S06",
      "agent": "qv-gate",
      "gate": "lint",
      "command": "make lint",
      "description": "QV: Linting"
    },
    {
      "step": "S07",
      "agent": "qv-gate",
      "gate": "format",
      "command": "make format",
      "description": "QV: Formatting"
    },
    {
      "step": "S08",
      "agent": "qv-gate",
      "gate": "typecheck",
      "command": "make typecheck",
      "description": "QV: Type checking"
    },
    {
      "step": "S09",
      "agent": "qv-gate",
      "gate": "unit-tests",
      "command": "make test-unit",
      "description": "QV: Unit tests"
    },
    {
      "step": "S10",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": "make allure-integration",
      "description": "QV: Integration tests",
      "timeout": 900
    },
    {
      "step": "S11",
      "agent": "qv-gate",
      "gate": "smoke",
      "command": "make smoke",
      "description": "QV: Smoke tests"
    }
  ]
}
