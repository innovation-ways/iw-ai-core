{
  "id": "F-00013",
  "type": "Feature",
  "title": "Project-Level Documentation System — Automation (Phase 3)",
  "browser_verification": false,
  "steps": [
    {
      "step": "S01",
      "agent": "backend-impl",
      "description": "Post-merge hook, find_docs_by_source_path, git-mtime staleness, iw docs-check-stale CLI, editorial lint gate, concurrent job limit",
      "prompt": "prompts/F-00013_S01_Backend_prompt.md"
    },
    {
      "step": "S02",
      "agent": "frontend-impl",
      "description": "Staleness badge on cards, stale summary row, Regenerate All, lint warnings callout, doc config panel",
      "prompt": "prompts/F-00013_S02_Frontend_prompt.md"
    },
    {
      "step": "S03",
      "agent": "tests-impl",
      "description": "Post-merge hook tests (git fixture), staleness detection, lint gate, config panel, boundary tests",
      "prompt": "prompts/F-00013_S03_Tests_prompt.md"
    },
    {
      "step": "S04",
      "agent": "code-review-final-impl",
      "description": "Final cross-agent review: all 8 AC, post-merge safety, lint correctness, git subprocess safety",
      "prompt": "prompts/F-00013_S04_CodeReview_Final_prompt.md"
    },
    {
      "step": "S05",
      "agent": "qv-gate",
      "gate": "lint",
      "command": "make lint",
      "description": "QV: Linting"
    },
    {
      "step": "S06",
      "agent": "qv-gate",
      "gate": "format",
      "command": "make format-check",
      "description": "QV: Formatting"
    },
    {
      "step": "S07",
      "agent": "qv-gate",
      "gate": "typecheck",
      "command": "make type-check",
      "description": "QV: Type checking"
    },
    {
      "step": "S08",
      "agent": "qv-gate",
      "gate": "arch-check",
      "command": "make arch-check",
      "description": "QV: Architecture"
    },
    {
      "step": "S09",
      "agent": "qv-gate",
      "gate": "security-sast",
      "command": "make security-sast",
      "description": "QV: Security SAST"
    },
    {
      "step": "S10",
      "agent": "qv-gate",
      "gate": "unit-tests",
      "command": "make test-unit",
      "description": "QV: Unit tests"
    },
    {
      "step": "S11",
      "agent": "qv-gate",
      "gate": "frontend-tests",
      "command": "make test-integration",
      "description": "QV: Frontend tests"
    },
    {
      "step": "S12",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": "make allure-integration",
      "description": "QV: Integration tests",
      "timeout": 900
    }
  ]
