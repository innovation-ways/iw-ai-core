{
  "id": "F-00020",
  "type": "Feature",
  "title": "Add Research Work Item Type to iw-ai-core",
  "browser_verification": false,
  "steps": [
    {
      "step": "S01",
      "agent": "database-impl",
      "description": "Two Alembic migrations: add 'Research' to work_item_type, add 'research' to doc_type",
      "prompt": "prompts/F-00020_S01_Database_prompt.md"
    },
    {
      "step": "S02",
      "agent": "backend-impl",
      "description": "WorkItemType.Research + DocType.research enums; extend CLI utils, id_commands, item_commands",
      "prompt": "prompts/F-00020_S02_Backend_prompt.md"
    },
    {
      "step": "S03",
      "agent": "code-review-impl",
      "description": "Code review of S02 Backend implementation",
      "prompt": "prompts/F-00020_S03_CodeReview_Backend_prompt.md"
    },
    {
      "step": "S04",
      "agent": "tests-impl",
      "description": "Integration tests: next-id research, register research, doc-update research, prefix mismatch",
      "prompt": "prompts/F-00020_S04_Tests_prompt.md"
    },
    {
      "step": "S05",
      "agent": "code-review-final-impl",
      "description": "Global review: completeness, consistency, full test suite",
      "prompt": "prompts/F-00020_S05_CodeReview_Final_prompt.md"
    },
    {
      "step": "S06",
      "agent": "qv-gate",
      "gate": "lint",
      "command": ".venv/bin/python -m ruff check orch/ tests/",
      "description": "QV: Linting (iw-ai-core)"
    },
    {
      "step": "S07",
      "agent": "qv-gate",
      "gate": "format",
      "command": ".venv/bin/python -m ruff format --check orch/ tests/",
      "description": "QV: Formatting (iw-ai-core)"
    },
    {
      "step": "S08",
      "agent": "qv-gate",
      "gate": "typecheck",
      "command": ".venv/bin/python -m mypy orch/db/models.py orch/cli/utils.py orch/cli/id_commands.py orch/cli/item_commands.py",
      "description": "QV: Type checking (iw-ai-core)"
    },
    {
      "step": "S09",
      "agent": "qv-gate",
      "gate": "unit-tests",
      "command": ".venv/bin/pytest tests/unit/ -x --timeout=60 -q 2>/dev/null || echo 'No unit tests — OK'",
      "description": "QV: Unit tests (iw-ai-core)"
    },
    {
      "step": "S10",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": ".venv/bin/pytest tests/integration/ -x --timeout=300 -q",
      "description": "QV: Integration tests (iw-ai-core)",
      "timeout": 600
    }
  ]
}
