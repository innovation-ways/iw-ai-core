{
  "id": "F-00041",
  "type": "Feature",
  "title": "Interactive Document IDE — Guide Editor & Diff Viewer UI",
  "browser_verification": true,
  "steps": [
    {
      "step": "S01",
      "agent": "frontend-impl",
      "description": "9 htmx endpoints in docs.py; 5 Jinja2 fragments; IDE tab on docs_detail.html",
      "prompt": "prompts/F-00041_S01_Frontend_prompt.md"
    },
    {
      "step": "S02",
      "agent": "code-review-impl",
      "description": "Code review of S01 Frontend implementation",
      "prompt": "prompts/F-00041_S02_CodeReview_Frontend_prompt.md"
    },
    {
      "step": "S03",
      "agent": "tests-impl",
      "description": "Integration tests for all 9 htmx endpoints",
      "prompt": "prompts/F-00041_S03_Tests_prompt.md"
    },
    {
      "step": "S04",
      "agent": "code-review-final-impl",
      "description": "Global review: completeness, all guide levels editable, diff panel renders",
      "prompt": "prompts/F-00041_S04_CodeReview_Final_prompt.md"
    },
    {
      "step": "S05",
      "agent": "qv-gate",
      "gate": "lint",
      "command": ".venv/bin/python -m ruff check dashboard/ tests/",
      "description": "QV: Linting"
    },
    {
      "step": "S06",
      "agent": "qv-gate",
      "gate": "format",
      "command": ".venv/bin/python -m ruff format --check dashboard/ tests/",
      "description": "QV: Formatting"
    },
    {
      "step": "S07",
      "agent": "qv-gate",
      "gate": "typecheck",
      "command": ".venv/bin/python -m mypy dashboard/routers/docs.py",
      "description": "QV: Type checking"
    },
    {
      "step": "S08",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": ".venv/bin/pytest tests/integration/ -x --timeout=300 -q",
      "description": "QV: Integration tests",
      "timeout": 600
    },
    {
      "step": "S09",
      "agent": "qv-browser",
      "description": "Playwright: open docs detail, click IDE tab, verify guide editor and diff panels load",
      "prompt": "prompts/F-00041_S09_QVBrowser_prompt.md"
    }
  ]
}
