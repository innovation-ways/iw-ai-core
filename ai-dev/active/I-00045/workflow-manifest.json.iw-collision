  "id": "I-00045",
  "type": "Issue",
  "title": "OSS status widget and page: ugly layout and raw JSON rendering",
  "browser_verification": true,
  "steps": [
    {
      "step": "S01",
      "agent": "frontend-impl",
      "description": "Fix oss_status_frame.html (readable summary pill, clickable heading, move Rescan, remove stale border) and oss.html (CSS dots, no emoji); run make css",
      "prompt": "prompts/I-00045_S01_Frontend_prompt.md"
    },
    {
      "step": "S02",
      "agent": "code-review-impl",
      "description": "Review S01 frontend template changes",
      "prompt": "prompts/I-00045_S02_CodeReview_Frontend_prompt.md"
    },
    {
      "step": "S03",
      "agent": "tests-impl",
      "description": "Write reproduction test (no raw JSON) and regression tests (formatted counts, heading link, no emoji)",
      "prompt": "prompts/I-00045_S03_Tests_prompt.md"
    },
    {
      "step": "S04",
      "agent": "code-review-impl",
      "description": "Review S03 test coverage for semantic correctness",
      "prompt": "prompts/I-00045_S04_CodeReview_Tests_prompt.md"
    },
    {
      "step": "S05",
      "agent": "code-review-final-impl",
      "description": "Global cross-agent review of all changes",
      "prompt": "prompts/I-00045_S05_CodeReview_Final_prompt.md"
    },
    {
      "step": "S06",
      "agent": "qv-gate",
      "gate": "lint",
      "command": "make lint",
      "description": "QV: Linting"
    },
    {
      "step": "S07",
      "agent": "qv-gate",
      "gate": "format",
      "command": "make format-check",
      "description": "QV: Formatting"
    },
    {
      "step": "S08",
      "agent": "qv-gate",
      "gate": "typecheck",
      "command": "make typecheck",
      "description": "QV: Type checking"
    },
    {
      "step": "S09",
      "agent": "qv-gate",
      "gate": "unit-tests",
      "command": "make test-unit",
      "description": "QV: Unit tests"
    },
    {
      "step": "S10",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": "make allure-integration",
      "description": "QV: Integration tests",
      "timeout": 900
    },
    {
