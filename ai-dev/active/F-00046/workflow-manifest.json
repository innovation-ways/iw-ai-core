{
  "id": "F-00046",
  "type": "Feature",
  "title": "Code Understanding: Indexing Engine + Level 1 Map Generation",
  "browser_verification": false,
  "steps": [
    {
      "step": "S01",
      "agent": "backend-impl",
      "description": "CodeIndexer + CodeIndexJobRunner + MapGenerator + start_index_job helper",
      "prompt": "prompts/F-00046_S01_Backend_prompt.md"
    },
    {
      "step": "S02",
      "agent": "code-review-impl",
      "description": "Review S01",
      "prompt": "prompts/F-00046_S02_CodeReview_prompt.md"
    },
    {
      "step": "S03",
      "agent": "tests-impl",
      "description": "Unit + integration tests for the Python indexing pipeline",
      "prompt": "prompts/F-00046_S03_Tests_prompt.md"
    },
    {
      "step": "S04",
      "agent": "code-review-impl",
      "description": "Review S03",
      "prompt": "prompts/F-00046_S04_CodeReview_prompt.md"
    },
    {
      "step": "S05",
      "agent": "code-review-final-impl",
      "description": "Final cross-agent review",
      "prompt": "prompts/F-00046_S05_CodeReview_Final_prompt.md"
    },
    {
      "step": "S06",
      "agent": "qv-gate",
      "gate": "lint",
      "command": "uv run ruff check .",
      "description": "QV: Lint"
    },
    {
      "step": "S07",
      "agent": "qv-gate",
      "gate": "format",
      "command": "uv run ruff format --check .",
      "description": "QV: Format"
    },
    {
      "step": "S08",
      "agent": "qv-gate",
      "gate": "typecheck",
      "command": "uv run mypy orch/ dashboard/",
      "description": "QV: Type check"
    },
    {
      "step": "S09",
      "agent": "qv-gate",
      "gate": "unit-tests",
      "command": "uv run pytest tests/unit/ -v",
      "description": "QV: Unit tests"
    },
    {
      "step": "S10",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": "uv run pytest tests/integration/ -v --alluredir=allure-results",
      "description": "QV: Integration tests",
      "timeout": 900
    },
    {
      "step": "S11",
      "agent": "qv-gate",
      "gate": "unit-tests",
      "command": "uv run pytest tests/unit/ -v",
      "description": "QV: Unit tests"
    },
    {
      "step": "S12",
      "agent": "qv-gate",
      "gate": "integration-tests",
      "command": "uv run pytest tests/integration/ -v --alluredir=allure-results",
      "description": "QV: Integration tests",
      "timeout": 900
    }
  ]
}
