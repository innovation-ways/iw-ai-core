{
  "_note": "This file is a design-time snapshot and may be out of date. For current step state, run: iw item-status <ID> --json. The DB is the authoritative source of truth (CR-00023).",
  "id": "CR-00065",
  "type": "ChangeRequest",
  "title": "Live Agent Session Log Viewer",
  "browser_verification": true,
  "scope": {
    "allowed_paths": [
      "orch/db/models.py",
      "orch/db/migrations/versions/**",
      "orch/daemon/step_monitor.py",
      "orch/daemon/session_reader.py",
      "dashboard/routers/items.py",
      "dashboard/templates/fragments/item_steps_table.html",
      "dashboard/templates/fragments/session_log_popup_content.html",
      "dashboard/static/styles.css",
      "tests/unit/test_session_reader.py",
      "tests/integration/test_step_run_session_file.py",
      "tests/dashboard/test_items_session_log.py",
      "ai-dev/active/CR-00065/**",
      "ai-dev/work/CR-00065/**"
    ]
  },
  "steps": [
    {
      "step": "S01",
      "agent": "database-impl",
      "step_type": "database",
      "description": "Add session_file TEXT NULL column to step_runs; Alembic migration",
      "prompt": "prompts/CR-00065_S01_Database_prompt.md"
    },
    {
      "step": "S02",
      "agent": "qv-gate",
      "step_type": "qv_gate",
      "gate": "migration-check",
      "command": "make migration-check",
      "description": "QV: Alembic migration round-trip + drift check",
      "prompt": "prompts/CR-00065_S02_MigrationCheck_prompt.md"
    },
    {
      "step": "S03",
      "agent": "backend-impl",
      "step_type": "backend",
      "description": "step_monitor resolves pi session file; session_reader module",
      "prompt": "prompts/CR-00065_S03_Backend_prompt.md"
    },
    {
      "step": "S04",
      "agent": "api-impl",
      "step_type": "api",
      "description": "GET session-log fragment endpoint in items router",
      "prompt": "prompts/CR-00065_S04_Api_prompt.md"
    },
    {
      "step": "S05",
      "agent": "frontend-impl",
      "step_type": "frontend",
      "description": "Logs column in item_steps_table + session_log_popup_content template",
      "prompt": "prompts/CR-00065_S05_Frontend_prompt.md"
    },
    {
      "step": "S06",
      "agent": "code-review-impl",
      "step_type": "code_review",
      "description": "Code review of S01-S05",
      "prompt": "prompts/CR-00065_S06_CodeReview_prompt.md"
    },
    {
      "step": "S07",
      "agent": "code-review-fix-impl",
      "step_type": "code_review_fix",
      "description": "Fix CRITICAL/HIGH/MEDIUM_FIXABLE review findings",
      "prompt": "prompts/CR-00065_S07_CodeReviewFix_prompt.md"
    },
    {
      "step": "S08",
      "agent": "code-review-final-impl",
      "step_type": "code_review_final",
      "description": "Cross-agent final review",
      "prompt": "prompts/CR-00065_S08_CodeReviewFinal_prompt.md"
    },
    {
      "step": "S09",
      "agent": "code-review-fix-final-impl",
      "step_type": "code_review_fix_final",
      "description": "Fix final review findings",
      "prompt": "prompts/CR-00065_S09_CodeReviewFixFinal_prompt.md"
    },
    {
      "step": "S10",
      "agent": "qv-gate",
      "step_type": "qv_gate",
      "gate": "integration-tests",
      "command": "make test-integration",
      "description": "QV: integration test suite",
      "prompt": "prompts/CR-00065_S10_QvGate_prompt.md"
    },
    {
      "step": "S11",
      "agent": "qv-browser",
      "step_type": "qv_browser",
      "description": "QV: Browser verification — Logs popup opens, renders session content, live-refreshes",
      "prompt": "prompts/CR-00065_S11_BrowserVerification_prompt.md"
    },
    {
      "step": "S12",
      "agent": "self-assess-impl",
      "step_type": "self_assess",
      "description": "Self-assessment of the just-completed item via the iw-item-analyze skill",
      "prompt": "prompts/CR-00065_S12_SelfAssess_prompt.md"
    }
  ]
}
