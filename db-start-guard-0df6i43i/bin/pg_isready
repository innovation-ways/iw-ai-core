#!/usr/bin/env bash
state_file="${DB_READY_STATE_FILE}"
sequence_csv="${DB_READY_SEQUENCE:-1}"
IFS=',' read -r -a sequence <<< "$sequence_csv"
idx=0
if [[ -f "$state_file" ]]; then
  idx=$(cat "$state_file")
fi
if (( idx < ${#sequence[@]} )); then
  code="${sequence[$idx]}"
else
  code="${sequence[-1]}"
fi
echo $((idx + 1)) > "$state_file"
exit "$code"
