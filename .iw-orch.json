{
  "project_id": "iw-ai-core",
  "cli_tool": "pi",
  "max_parallel": 4,
  "overlap_gate": {
    "block_on_overlap": [
      "**/*"
    ],
    "allow_on_overlap": [
      "tests/**",
      "test/**",
      "__tests__/**",
      "**/*conftest*",
      "**/*.test.*",
      "**/*.spec.*",
      "**/*.md",
      "skills/**",
      ".claude/skills/**",
      "ai-dev/**"
    ]
  },
  "auto_publish": false,
  "browser_verification": {
    "env_up_command": "scripts/e2e_up.sh",
    "env_down_command": "scripts/e2e_down.sh",
    "base_url_template": "http://localhost:${E2E_FRONTEND_PORT}",
    "port_pool": {
      "frontend_base": 9910,
      "api_base": 9910,
      "db_base": 5442,
      "redis_base": 6389,
      "pool_size": 50
    },
    "compose_project_prefix": "iw-ai-core-e2e"
  },
  "fix_cycle_max": 5,
  "post_archive_commands": [
    "uv run alembic upgrade head"
  ],
  "test_config": {
    "execution_dir": "/home/sergiog/dev/iw-doc-plan/main/iw-ai-core",
    "allure_results_dir": "allure-results",
    "allure_report_dir": "allure-report",
    "categories": {
      "unit": {
        "label": "Unit Tests",
        "command": "uv run pytest tests/unit/ -v --alluredir=allure-results",
        "description": "Fast tests, no external dependencies",
        "group": "backend"
      },
      "integration": {
        "label": "Integration Tests",
        "command": "uv run pytest tests/integration/ -v --alluredir=allure-results",
        "description": "Requires PostgreSQL testcontainer",
        "group": "backend"
      },
      "all": {
        "label": "Run All Tests",
        "command": "uv run pytest tests/ -v --alluredir=allure-results",
        "description": "Complete test suite (unit + integration)",
        "group": "suites",
        "bundle": true
      }
    }
  },
  "quality_config": {
    "execution_dir": "/home/sergiog/dev/iw-doc-plan/main/iw-ai-core",
    "categories": {
      "lint": {
        "label": "Lint (Ruff)",
        "description": "Code style and linting checks",
        "command": "make lint",
        "group": "style"
      },
      "format": {
        "label": "Format Check (Ruff)",
        "description": "Code formatting verification",
        "command": "make format",
        "group": "style"
      },
      "typecheck": {
        "label": "Type Check (Mypy)",
        "description": "Strict static type checking on orch/ and dashboard/",
        "command": "make typecheck",
        "group": "style"
      },
      "all-quality": {
        "label": "Run All Quality Gates",
        "description": "Lint + format + type check",
        "command": "make quality",
        "group": "suites",
        "bundle": true
      }
    }
  },
  "_auto_amend_scope_example": {
    "_note": "Uncomment by renaming to 'auto_amend_scope'. When present, the daemon auto-amends scope violations that all match auto_allow_patterns and stay within max_paths. Default (key absent) keeps today's manual amend flow.",
    "auto_allow_patterns": [
      "tests/**",
      "**/*.md",
      "docs/**",
      "ai-dev/**"
    ],
    "max_paths": 10
  }
}
