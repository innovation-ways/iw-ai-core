{
  "project_id": "iw-ai-core",
  "cli_tool": "opencode",
  "max_parallel": 4,
  "auto_publish": false,
  "browser_verification": false,
  "fix_cycle_max": 5,
  "post_archive_commands": [
    "uv run alembic upgrade head"
  ],
  "test_config": {
    "execution_dir": "/home/sergiog/dev/iw-doc-plan/main/iw-ai-core",
    "allure_results_dir": "allure-results",
    "allure_report_dir": "allure-report",
    "categories": {
      "unit": {
        "label": "Unit Tests",
        "command": "uv run pytest tests/unit/ -v --alluredir=allure-results",
        "description": "Fast tests, no external dependencies",
        "group": "backend"
      },
      "integration": {
        "label": "Integration Tests",
        "command": "uv run pytest tests/integration/ -v --alluredir=allure-results",
        "description": "Requires PostgreSQL testcontainer",
        "group": "backend"
      },
      "all": {
        "label": "Run All Tests",
        "command": "uv run pytest tests/ -v --alluredir=allure-results",
        "description": "Complete test suite (unit + integration)",
        "group": "suites",
        "bundle": true
      }
    }
  },
  "quality_config": {
    "execution_dir": "/home/sergiog/dev/iw-doc-plan/main/iw-ai-core",
    "categories": {
      "lint": {
        "label": "Lint (Ruff)",
        "description": "Code style and linting checks",
        "command": "make lint",
        "group": "style"
      },
      "format": {
        "label": "Format Check (Ruff)",
        "description": "Code formatting verification",
        "command": "make format",
        "group": "style"
      },
      "typecheck": {
        "label": "Type Check (Mypy)",
        "description": "Strict static type checking on orch/ and dashboard/",
        "command": "make typecheck",
        "group": "style"
      },
      "all-quality": {
        "label": "Run All Quality Gates",
        "description": "Lint + format + type check",
        "command": "make quality",
        "group": "suites",
        "bundle": true
      }
    }
  }
}
