# ============================================================
# IW AI Core — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# .env is in .gitignore — never committed.
# ============================================================

# --- Database ---
IW_CORE_DB_HOST=localhost
IW_CORE_DB_PORT=5433
IW_CORE_DB_NAME=iw_orch
IW_CORE_DB_USER=iw_orch
IW_CORE_DB_PASSWORD=iw_orch_dev

# Computed by the application from the above:
# IW_CORE_DB_URL=postgresql+psycopg://${IW_CORE_DB_USER}:${IW_CORE_DB_PASSWORD}@${IW_CORE_DB_HOST}:${IW_CORE_DB_PORT}/${IW_CORE_DB_NAME}

# Global orch DB pointer (F-00062). Inside per-worktree compose stacks the
# IW_CORE_DB_* vars are remapped to the worktree's local DB; IW_CORE_ORCH_DB_*
# always points at the global orch DB on 5433 so seed scripts can pg_dump from it.
# On the daemon host these mirror IW_CORE_DB_* above.
IW_CORE_ORCH_DB_HOST=localhost
IW_CORE_ORCH_DB_PORT=5433
IW_CORE_ORCH_DB_NAME=iw_orch
IW_CORE_ORCH_DB_USER=iw_orch
IW_CORE_ORCH_DB_PASSWORD=iw_orch_dev

# --- Database connection pool ---
# Number of persistent connections kept open (default: 20)
IW_CORE_DB_POOL_SIZE=20
# Additional connections allowed when pool is saturated (default: 20)
IW_CORE_DB_MAX_OVERFLOW=20

# --- Request observability ---
# Slow request threshold in ms — requests above this emit a WARN log (default: 500)
IW_CORE_SLOW_REQUEST_MS=500

# --- Cache TTLs (seconds) ---
# TTL for the sidebar worktree-badge dirty count cache (default: 30)
IW_CORE_BADGE_CACHE_TTL=30
# TTL for git branch/stats and worktree-status caches (default: 15)
IW_CORE_GIT_STATS_CACHE_TTL=15

# --- Dashboard ---
IW_CORE_DASHBOARD_HOST=0.0.0.0
IW_CORE_DASHBOARD_PORT=9900

# --- Daemon ---
# Poll interval in seconds (how often the daemon checks for work)
IW_CORE_POLL_INTERVAL=60
# Stall threshold in seconds (step with no heartbeat for this long is stalled)
IW_CORE_STALL_THRESHOLD=600
# PID file path (relative to repo root)
IW_CORE_PID_FILE=.daemon.pid

# --- Archive ---
# Directory for compressed artifacts (not committed to git)
IW_CORE_ARCHIVE_DIR=./archive
# Archive TTL in days (archives older than this are eligible for cleanup)
IW_CORE_ARCHIVE_TTL=600

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
IW_CORE_LOG_LEVEL=INFO
# Log file path (relative to repo root)
IW_CORE_LOG_FILE=./logs/daemon.log

# -----------------------------------------------------------------------------
# DB instance-identity fingerprint (CR-00014)
# -----------------------------------------------------------------------------
# The orchestration DB seeds a UUID into iw_core_instance on first migration.
# Set this to that UUID so every process verifies it's talking to the right
# DB. To find the current value:  uv run iw db-identity show
# Leaving this unset puts the system in bootstrap mode (warns instead of
# refusing). Do NOT commit a populated value from production.
IW_CORE_EXPECTED_INSTANCE_ID=
